# IronBuddy 环境变量模板
# ----------------------------------------------------------------------
# 用法：
#   cp .env.example .env        # 填真实值，.env 已在 .gitignore
#   或 cp .env.example ~/.ironbuddy/secrets.env  （库会优先读取这里）
#
# 飞书（FeishuClient 会按 env → ~/.ironbuddy/secrets.env → .api_config.json
# 的顺序回退查找）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_secret_here
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 演示前安全默认：1 = dry-run（只打 log，不真发）；0 = 真发
IRONBUDDY_FEISHU_DRY_RUN=1

# DeepSeek（streamer_app 的 /api/feishu/push 也会读）
DEEPSEEK_API_KEY=sk-xxxxxxxx

# OpenClaw Daemon 定时触发点（可选，默认见 openclaw_daemon.py）
# DAILY_PLAN_HOUR=9
# WEEKLY_REPORT_DOW=6
# WEEKLY_REPORT_HOUR=20
# PREFERENCE_HOUR=23
