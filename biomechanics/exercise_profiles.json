{
  "squat": {
    "name": "深蹲",
    "primary_joints": ["l_knee", "r_knee", "l_hip", "r_hip"],
    "muscles": {
      "quadriceps":     {"role": "primary",    "joints": ["l_knee", "r_knee"],       "action": "extension"},
      "glutes":         {"role": "primary",    "joints": ["l_hip", "r_hip"],         "action": "extension"},
      "hamstrings":     {"role": "synergist",  "joints": ["l_knee", "r_knee", "l_hip", "r_hip"], "action": "flexion"},
      "calves":         {"role": "synergist",  "joints": ["l_knee", "r_knee"],       "action": "stabilize"},
      "erector_spinae": {"role": "synergist",  "joints": ["l_hip", "r_hip"],         "action": "extension"},
      "abs":            {"role": "stabilizer", "joints": ["l_hip", "r_hip"],         "action": "stabilize"},
      "hip_adductors":  {"role": "stabilizer", "joints": ["l_hip", "r_hip"],         "action": "stabilize"}
    }
  },
  "bicep_curl": {
    "name": "哑铃弯举",
    "primary_joints": ["l_elbow", "r_elbow"],
    "muscles": {
      "biceps":              {"role": "primary",    "joints": ["l_elbow", "r_elbow"],         "action": "flexion"},
      "brachialis":          {"role": "synergist",  "joints": ["l_elbow", "r_elbow"],         "action": "flexion"},
      "brachioradialis":     {"role": "synergist",  "joints": ["l_elbow", "r_elbow"],         "action": "flexion"},
      "anterior_deltoid":    {"role": "stabilizer", "joints": ["l_shoulder", "r_shoulder"],   "action": "stabilize"},
      "trapezius":           {"role": "stabilizer", "joints": ["l_shoulder", "r_shoulder"],   "action": "stabilize"},
      "forearm_flexors":     {"role": "stabilizer", "joints": ["l_elbow", "r_elbow"],         "action": "stabilize"}
    }
  }
}
